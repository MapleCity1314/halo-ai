{
  "name": "halo-ai",
  "private": true,
  "keywords": [
    "agent",
    "ai",
    "cache-first",
    "deepseek",
    "llm"
  ],
  "homepage": "https://github.com/halo-sdk/halo-ai#readme",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/halo-sdk/halo-ai"
  },
  "workspaces": [
    "packages/*",
    "examples/*",
    "docs"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "lint": "oxlint packages",
    "publint": "turbo publint",
    "format": "oxfmt packages",
    "format:check": "oxfmt --check packages",
    "typecheck": "tsc --build",
    "clean": "turbo clean",
    "changeset": "changeset",
    "ci:version": "changeset version",
    "ci:release": "turbo build && changeset publish",
    "docs:dev": "pnpm --filter @halo-sdk/docs dev",
    "docs:build": "pnpm --filter @halo-sdk/docs build",
    "example:dev": "pnpm --filter @example/next-halo dev",
    "setup": "pnpm install && pnpm build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.0.0",
    "del-cli": "^7.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "publint": "^0.3.21",
    "tsup": "^8.5.1",
    "turbo": "^2.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "oxfmt --write",
      "oxlint"
    ],
    "*.{json,md}": [
      "oxfmt --write"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0"
}
