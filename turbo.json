{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": ["DEEPSEEK_API_KEY"]
    },
    "test": {
      "dependsOn": ["^build"],
      "env": ["DEEPSEEK_API_KEY"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "cache": false
    },
    "publint": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "format:check": {
      "cache": false
    },
    "docs:build": {
      "outputs": [".vitepress/dist/**"]
    },
    "example:dev": {
      "cache": false,
      "persistent": true
    }
  }
}
