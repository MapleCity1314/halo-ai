{
  "name": "@halo-sdk/stream",
  "version": "1.0.0",
  "description": "Streaming utilities for Halo AI SDK — SSE Response for Vercel AI SDK compatibility",
  "license": "MIT",
  "keywords": [
    "ai",
    "llm",
    "streaming",
    "sse",
    "vercel-ai-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/halo-sdk/halo-ai",
    "directory": "packages/stream"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@halo-sdk/core": ">=1.0.0"
  },
  "devDependencies": {
    "@halo-sdk/core": "workspace:*",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
