{
  "name": "@halo-sdk/mcp",
  "version": "1.1.0",
  "description": "MCP (Model Context Protocol) integration for Halo AI SDK — connect to MCP servers and use their tools with cache-first agents",
  "license": "MIT",
  "keywords": [
    "ai",
    "llm",
    "agent",
    "mcp",
    "model-context-protocol",
    "halo-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/halo-sdk/halo-ai",
    "directory": "packages/mcp"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@halo-sdk/core": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@halo-sdk/core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
